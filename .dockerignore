.env
.env.local
.env.*.local
.env.production

# Logs
logs/
*.log
npm-debug.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Coverage
coverage/
.nyc_output/

# Docker data
docker-data/

# Certificates
*.pem
*.key
*.crt
*.csr

# Backups
backups/
*.sql.gz
*.tar.gz

# Temp
tmp/
temp/
*.tmp

# OS junk
.DS_Store
Thumbs.db
Desktop.ini

# Git
.git/
.gitignore
.gitattributes

# Package locks (use npm install inside container)
package-lock.json

# Documentation (not needed for build)
docs/

