# =============================================================================
# HostPanel Pro - Environment Configuration
# =============================================================================

# --- Environment ---
NODE_ENV=development
LOG_LEVEL=debug

# --- Database ---
DATABASE_URL=postgresql://hostpanel:hostpanel_pass@localhost:5432/hostpanel

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- JWT / Auth ---
JWT_SECRET=change_this_to_a_strong_random_secret_at_least_64_chars_long
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
ENCRYPTION_KEY=change_this_to_a_strong_random_64_byte_key
BCRYPT_ROUNDS=12

# --- 2FA ---
TOTP_ISSUER=HostPanelPro
TOTP_WINDOW=1

# --- Session ---
SESSION_SECRET=change_this_to_another_strong_random_secret
SESSION_MAX_AGE=86400000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_APP_NAME=HostPanel Pro
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- API ---
API_HOST=0.0.0.0
API_PORT=3001
API_CORS_ORIGIN=http://localhost:3000

# --- Worker ---
WORKER_CONCURRENCY=10
WORKER_POLL_INTERVAL=1000

# --- Agent ---
AGENT_API_KEY=change_this_to_agent_api_key
AGENT_URL=http://localhost:3002
AGENT_PORT=3002

# --- Email ---
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@hostpanel.local
SMTP_SECURE=false

# --- Backup ---
BACKUP_DIR=/var/backups/hostpanel
BACKUP_RETENTION_DAYS=30

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# --- Security ---
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SYMBOLS=true

# --- File Manager ---
FILE_MANAGER_MAX_UPLOAD_MB=128
FILE_MANAGER_BLOCKED_EXTENSIONS=php,php5,php7,phtml,cgi,pl,py,rb,sh,bash,exe,com,bat,cmd,msi,dll,so

# --- Monitoring ---
METRICS_COLLECTION_INTERVAL_MS=60000
METRICS_RETENTION_DAYS=90

# --- Feature Flags ---
FF_ENABLE_DOCKER=false
FF_ENABLE_GIT_DEPLOY=false
FF_ENABLE_WORDPRESS_TOOLKIT=true
FF_ENABLE_MAIL=false
FF_ENABLE_DNS=false
FF_ENABLE_MOCK_AGENT=true